{
    "manifest_version": 3,
    "name": "As wep app",
    "description": "Open sites in a window without any browser decorations. For when you want the Progressive Web App (PWA) or Site Specific Browser (SSB) experience.",
    "version": "20260303",
    "author": "feraxhp",
    "license": "MIT",
    "permissions": ["tabs", "webNavigation", "contextMenus"],
    "background": {
        "scripts": ["background.js"]
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "@wam.feraxhp",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "commands": {
        "preserve": {
            "description": "Opens the tab in preserve mode",
            "suggested_key": {
                "default": "Alt+P"
            }
        },
        "as_copy": {
            "description": "Opens a clone of the tab",
            "suggested_key": {
                "default": "Alt+K"
            }
        }
    }
}
